# Server-side values used by the local Vite Foundry proxy.
AZURE_OPENAI_API_KEY=""
AZURE_AI_PROJECT_ENDPOINT="https://res-jsaibuildathon.services.ai.azure.com/api/projects/jsaibuildathon"
AZURE_OPENAI_ENDPOINT="https://res-jsaibuildathon.openai.azure.com/openai/v1"
AZURE_OPENAI_DEPLOYMENT="gpt-4.1-mini"
FOUNDRY_AGENT_NAME="StudioMillionaireAgent"
# Optional. Leave blank to let Foundry use the latest/default published agent version.
FOUNDRY_AGENT_VERSION=""
# Use "azure-cli" locally after az login. Use "managed-identity" in Azure production hosting.
AZURE_FOUNDRY_AGENT_AUTH="azure-cli"
AZURE_FOUNDRY_TOKEN_RESOURCE="https://ai.azure.com"
# Optional on Windows if Node cannot find Azure CLI automatically.
AZURE_CLI_PATH="C:\\Program Files (x86)\\Microsoft SDKs\\Azure\\CLI2\\wbin\\az.cmd"

# Browser-visible defaults for the settings UI.
VITE_AZURE_AI_PROJECT_ENDPOINT="https://res-jsaibuildathon.services.ai.azure.com/api/projects/jsaibuildathon"
VITE_AZURE_OPENAI_ENDPOINT="https://res-jsaibuildathon.openai.azure.com/openai/v1"
VITE_AZURE_OPENAI_DEPLOYMENT="gpt-4.1-mini"
VITE_FOUNDRY_AGENT_ENABLED="true"
VITE_FOUNDRY_AGENT_NAME="StudioMillionaireAgent"
VITE_FOUNDRY_AGENT_VERSION=""
VITE_FOUNDRY_AGENT_AUTO_APPROVE="true"
VITE_CUSTOM_SHOW_ENABLED="false"
VITE_CUSTOM_SHOW_TITLE="Studio Millionaire Custom Show"
VITE_CUSTOM_SHOW_TOPIC=""
VITE_CUSTOM_SHOW_SOURCE=""
